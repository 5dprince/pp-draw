{
  "name": "pp-draw",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite --host 127.0.0.1\" \"tsx watch --clear-screen=false server/index.ts\"",
    "api": "tsx watch --clear-screen=false server/index.ts",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "node -e \"require('node:fs').rmSync('dist-server',{recursive:true,force:true})\" && esbuild server/index.ts --bundle --platform=node --target=node24 --format=esm --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\" --minify --legal-comments=none --outfile=dist-server/index.js",
    "lint": "oxlint",
    "preview": "vite preview",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.16"
  },
  "devDependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "lucide-react": "^1.23.0",
    "oxlint": "^1.71.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
